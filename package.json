{
  "name": "mediocre-rn-hass-media-controller",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|@material/material-color-utilities|home-assistant-js-websocket))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/slider": "^5.2.0",
    "@tanstack/react-form": "^1.28.6",
    "arktype": "^2.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~4.0.22",
    "expo-secure-store": "^55.0.11",
    "expo-status-bar": "~3.0.9",
    "home-assistant-js-websocket": "^9.6.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-remix-icon": "^4.7.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "eslint": "^9",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.13",
    "typescript": "~5.9.2"
  },
  "private": true
}
